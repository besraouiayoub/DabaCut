<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/choose_role"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:textSize="28sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/select_profile"
            android:textColor="@color/text_secondary"
            android:textSize="15sp" />

        <Button
            android:id="@+id/btnClient"
            style="@style/DabaButtonPrimary"
            android:layout_marginTop="40dp"
            android:text="@string/client" />

        <Button
            android:id="@+id/btnSalonHomme"
            style="@style/DabaButtonPrimary"
            android:layout_marginTop="16dp"
            android:text="@string/salon_homme" />

        <Button
            android:id="@+id/btnSalonFilles"
            style="@style/DabaButtonPrimary"
            android:layout_marginTop="16dp"
            android:text="@string/salon_filles" />

    </LinearLayout>
</ScrollView>